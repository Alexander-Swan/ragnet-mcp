# Copy to .env or run scripts/setup.* to generate the Docker Compose settings.
RAGNET_MCP_PORT=7331
RAGNET_QDRANT_BASE_URL=http://qdrant:6333
RAGNET_OLLAMA_BASE_URL=http://ollama:11434
RAGNET_EMBEDDING_MODEL=mxbai-embed-large
RAGNET_QDRANT_CPUS=2
RAGNET_QDRANT_MEM_LIMIT=4g
RAGNET_OLLAMA_CPUS=4
RAGNET_OLLAMA_MEM_LIMIT=8g
RAGNET_OLLAMA_NUM_PARALLEL=1
RAGNET_OLLAMA_MAX_LOADED_MODELS=1
RAGNET_OLLAMA_KEEP_ALIVE=30s
RAGNET_MCP_CPUS=1
RAGNET_MCP_MEM_LIMIT=1g
