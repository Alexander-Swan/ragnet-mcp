{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RagNet": {
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "EmbeddingModel": "mxbai-embed-large"
    },
    "Qdrant": {
      "BaseUrl": "http://localhost:6333",
      "CollectionPrefix": "ragnet",
      "UpsertBatchSize": 256
    },
    "Workspace": {
      "AutoIndex": false,
      "AllowedPaths": [],
      "ExcludeDirectories": [
        ".git",
        ".ragnet",
        ".vs",
        ".vscode",
        "bin",
        "obj",
        "node_modules",
        "packages"
      ],
      "ExcludeFilePatterns": [
        "*.g.cs",
        "*.Designer.cs"
      ],
      "ExcludeAutoGeneratedFiles": true
    },
    "WorkspaceGroups": [
    ],
    "Indexing": {
      "ChunkMaxChars": 30000,
      "MaxEmbeddingConcurrency": 4,
      "MaxEmbeddingBatchSize": 16
    },
    "Classification": {
      "DocumentationPathPatterns": [
        "**/doc/**",
        "**/docs/**",
        "**/documentation/**",
        "**/api-docs/**",
        "**/generated-docs/**"
      ],
      "ApplicationMarkupPathPatterns": [
        "**/src/**",
        "**/app/**",
        "**/apps/**",
        "**/client/**",
        "**/frontend/**",
        "**/ui/**",
        "**/views/**",
        "**/pages/**",
        "**/components/**",
        "**/wwwroot/**"
      ]
    }
  }
}
